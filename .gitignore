# pyenv
#   For a library or package, you might want to ignore these files since the Python version
#   is generally handled by the user. In an application, you might want to check them in.
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you must ignore it, uncomment the following line:
# Pipfile.lock

# poetry
#   Similar to Pipenv, see https://python-poetry.org/docs/basic-usage/#commit-your-lock-file-to-version-control
# poetry.lock

# pdm
#   Similar to Pipenv, see https://pdm.fming.dev/latest/usage/project/#working-with-version-control
.pdm-python
.pdm-build/

